{
  "name": "fm365",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,server -c blue,green \"vite\" \"tsx watch server/index.ts\"",
    "dev:vite": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
